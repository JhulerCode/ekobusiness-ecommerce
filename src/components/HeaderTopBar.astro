---
import ChevronDownIcon from '../assets/icons/icon-chevron-down.astro'
---

<div class="bg-sunka-ink text-[11px] tracking-wide text-sunka-white/85">
    <div class="mx-auto grid h-7 max-w-7xl grid-cols-3 items-center px-5 md:px-8">
        <p class="justify-self-start">Envios a todo el Peru</p>
        <p class="hidden justify-self-center text-center md:block">
            Envio gratis por compras mayores a S/199
        </p>
        <button class="hidden items-center gap-1 justify-self-end text-sunka-white/80 md:flex">
            Peru
            <ChevronDownIcon />
        </button>
    </div>
</div>
