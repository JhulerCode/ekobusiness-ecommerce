---
import logo from '../assets/logo-sunka-white.webp'
import imgLibroReclamaciones from '../assets/libro-reclamaciones.webp'
import BrandFacebookIcon from '../assets/icons/brand-facebook.astro'
import BrandInstagramIcon from '../assets/icons/brand-instagram.astro'
import BrandWhatsappIcon from '../assets/icons/brand-whatsapp.astro'
import BrandPinterestIcon from '../assets/icons/brand-pinterest.astro'
import { get } from '../lib/api.js'

const res = await get('sistema', {
    qry: ['empresa'],
})

const empresa = res.data?.empresa ?? {}

const columnas = [
    {
        titulo: 'Tienda',
        links: [
            { texto: 'Todas las colecciones', href: '/tienda' },
            { texto: 'Tes', href: '/tienda' },
            { texto: 'Infusiones', href: '/tienda' },
            { texto: 'Accesorios', href: '/tienda' },
            { texto: 'Ofertas', href: '/tienda' },
        ],
    },
    {
        titulo: 'Crea tu blend',
        links: [
            { texto: 'Como funciona', href: '/crea-tu-blend' },
            { texto: 'Ingredientes', href: '/crea-tu-blend' },
            { texto: 'Formatos y empaques', href: '/crea-tu-blend' },
            { texto: 'Preguntas frecuentes', href: '/faq' },
        ],
    },
    {
        titulo: 'Sunka',
        links: [
            { texto: 'Nuestro origen', href: '/origen' },
            { texto: 'Rituales', href: '/inspiracion' },
            { texto: 'Club Sunka', href: '/account' },
            { texto: 'Blog / Cartas Sunka', href: '/inspiracion' },
            { texto: 'Contacto', href: `mailto:${empresa.email_ventas}` },
        ],
    },
    {
        titulo: 'Ayuda',
        links: [
            { texto: 'Envios', href: '/politica-de-despacho' },
            { texto: 'Cambio y devoluciones', href: '/terminos-y-condiciones' },
            { texto: 'Metodos de pago', href: '/faq' },
            { texto: 'Preguntas frecuentes', href: '/faq' },
            { texto: 'Consultar pedido', href: '/consulta-pedido' },
        ],
    },
]
---

<footer class="bg-sunka-forest text-sunka-white">
    <section class="bg-[#111a13]">
        <div class="mx-auto max-w-7xl px-5 py-8 md:px-8">
            <div class="grid gap-9 md:grid-cols-[1.35fr_repeat(4,1fr)_1fr] md:gap-10">
                <div>
                    <img src={logo.src} alt="Sunka" class="h-10" />
                    <p class="mt-5 max-w-[230px] text-xs leading-relaxed text-sunka-white/66">
                        El ritual peruano del bienestar moderno. Te, infusiones y blends creados
                        para cada momento de tu vida.
                    </p>
                </div>

                {
                    columnas.map((columna) => (
                        <nav aria-label={columna.titulo}>
                            <h3 class="text-xs font-semibold uppercase tracking-[0.12em] text-sunka-white/88">
                                {columna.titulo}
                            </h3>
                            <ul class="mt-3 space-y-1.5 text-xs leading-relaxed text-sunka-white/62">
                                {columna.links.map((link) => (
                                    <li>
                                        <a
                                            href={link.href}
                                            class="transition hover:text-sunka-white"
                                        >
                                            {link.texto}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </nav>
                    ))
                }

                <div>
                    <h3
                        class="text-xs font-semibold uppercase tracking-[0.12em] text-sunka-white/88"
                    >
                        Siguenos
                    </h3>
                    <div class="mt-4 flex flex-wrap gap-2.5 text-sunka-white/72">
                        <a
                            href={empresa.instagram_url}
                            aria-label="Instagram"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex h-8 w-8 items-center justify-center rounded-full border border-sunka-white/18 transition hover:border-sunka-brass-light hover:text-sunka-brass-light"
                        >
                            <BrandInstagramIcon />
                        </a>
                        <a
                            href={empresa.facebook_url}
                            aria-label="Facebook"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex h-8 w-8 items-center justify-center rounded-full border border-sunka-white/18 transition hover:border-sunka-brass-light hover:text-sunka-brass-light"
                        >
                            <BrandFacebookIcon />
                        </a>
                        <a
                            href={empresa.whatsapp_ventas_url}
                            aria-label="WhatsApp"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex h-8 w-8 items-center justify-center rounded-full border border-sunka-white/18 transition hover:border-sunka-brass-light hover:text-sunka-brass-light"
                        >
                            <BrandWhatsappIcon />
                        </a>
                        <a
                            href={empresa.pinterest_url ?? '#'}
                            aria-label="Pinterest"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex h-8 w-8 items-center justify-center rounded-full border border-sunka-white/18 transition hover:border-sunka-brass-light hover:text-sunka-brass-light"
                        >
                            <BrandPinterestIcon />
                        </a>
                    </div>
                    <a href="/libro-de-reclamaciones" class="mt-5 inline-flex">
                        <img
                            src={imgLibroReclamaciones.src}
                            alt="Libro de reclamaciones"
                            class="h-10 opacity-80 transition hover:opacity-100"
                        />
                    </a>
                </div>
            </div>

            <div
                class="mt-8 grid gap-4 border-t border-sunka-white/10 pt-5 text-xs text-sunka-white/48 md:grid-cols-3 md:items-center"
            >
                <p>© {new Date().getFullYear()} Sunka. Todos los derechos reservados.</p>
                <div class="flex flex-wrap gap-x-6 gap-y-2 md:justify-center">
                    <a href="/politica-de-privacidad" class="transition hover:text-sunka-white">
                        Politicas de privacidad
                    </a>
                    <a href="/terminos-y-condiciones" class="transition hover:text-sunka-white">
                        Terminos y condiciones
                    </a>
                </div>
                <p class="flex items-center gap-2 md:justify-end">
                    <span>Hecho en Perú</span>
                    <span
                        class="inline-flex h-4 w-6 overflow-hidden rounded-[1px]"
                        aria-hidden="true"
                    >
                        <span class="h-full flex-1 bg-[#d91023]"></span>
                        <span class="h-full flex-1 bg-white"></span>
                        <span class="h-full flex-1 bg-[#d91023]"></span>
                    </span>
                </p>
            </div>
        </div>
    </section>
</footer>
