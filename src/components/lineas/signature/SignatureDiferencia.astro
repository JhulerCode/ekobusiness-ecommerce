---
import signature from '@/assets/home/lineas/signature.webp'
import DropIcon from '@/assets/icons/icon-drop.astro'
import BoxIcon from '@/assets/icons/icon-box.astro'
import ShieldCheckIcon from '@/assets/icons/icon-shield-check.astro'
import LeafIcon from '@/assets/icons/icon-leaf.astro'

const atributos = [
    {
        titulo: '1.5 g',
        texto: 'mayor gramaje por filtrante',
        Icon: DropIcon,
        iconClass: 'scale-[0.86]',
    },
    {
        titulo: '20',
        texto: 'sobres doble camara',
        Icon: BoxIcon,
        iconClass: 'scale-[0.86]',
    },
    {
        titulo: 'ISO',
        texto: 'calidad consistente',
        Icon: ShieldCheckIcon,
        iconClass: 'scale-[1.05]',
    },
    {
        titulo: 'RA',
        texto: 'Rainforest Alliance',
        Icon: LeafIcon,
        iconClass: 'scale-[0.82]',
    },
]
---

<section class="mt-1 w-full overflow-hidden bg-sunka-forest">
    <div class="mx-auto grid max-w-7xl grid-cols-1 md:grid-cols-[52%_48%]">
        <div class="bg-sunka-forest text-sunka-white">
            <div class="px-5 py-12 md:px-7 md:py-10 lg:px-8 lg:py-12">
                <div class="max-w-md">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-sunka-brass-light">
                        La diferencia esta en la taza
                    </p>
                    <h2 class="mt-3 font-heading text-3xl font-semibold leading-tight md:text-4xl">
                        Mas aroma, mas cuerpo y mejor liberacion de sabor.
                    </h2>
                    <p class="mt-4 max-w-sm text-sm leading-relaxed text-sunka-white/86 md:text-base">
                        El formato doble camara permite una infusion mas uniforme. El diferencial
                        tecnico se comunica con lenguaje claro, premium y facil de leer.
                    </p>
                    <a
                        href="#preparacion"
                        class="mt-7 inline-flex h-11 items-center justify-center border border-sunka-white/55 px-6 text-[12px] font-semibold uppercase tracking-[0.12em] text-sunka-white transition-colors duration-300 hover:border-sunka-brass hover:bg-sunka-brass hover:text-sunka-ink"
                    >
                        Conocer el formato
                    </a>
                </div>
            </div>

            <div class="grid px-4 py-6 text-sunka-white sm:grid-cols-4 md:grid-cols-2 md:px-6 md:py-7 lg:grid-cols-4 lg:px-0 lg:py-0">
                {
                    atributos.map((atributo, index) => {
                        const Icon = atributo.Icon

                        return (
                            <div
                                class={`relative flex min-h-[130px] flex-col items-center justify-center px-2 py-4 text-center lg:min-h-[155px] lg:py-5 ${
                                    index > 0
                                        ? 'lg:before:absolute lg:before:left-0 lg:before:top-1/2 lg:before:h-16 lg:before:w-[2px] lg:before:-translate-y-1/2 lg:before:bg-sunka-white/24'
                                        : ''
                                }`}
                            >
                                <span class="flex h-8 items-center justify-center text-sunka-brass-light">
                                    <Icon class={`h-7 w-7 ${atributo.iconClass}`} />
                                </span>
                                <p class="mt-2 flex min-h-8 items-center font-heading text-xl font-semibold leading-tight">
                                    {atributo.titulo}
                                </p>
                                <p class="flex min-h-8 max-w-[110px] items-start text-xs leading-snug text-sunka-white/78">
                                    {atributo.texto}
                                </p>
                            </div>
                        )
                    })
                }
            </div>
        </div>

        <div class="relative min-h-[320px] overflow-hidden md:min-h-full">
            <img
                src={signature.src}
                alt="Coleccion Signature Black con taza servida"
                class="absolute inset-0 h-full w-full object-cover object-left"
            />
            <!-- <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(7,10,7,.08)_0%,rgba(7,10,7,.18)_100%)] md:bg-[linear-gradient(90deg,rgba(7,10,7,.18)_0%,rgba(7,10,7,.04)_42%,rgba(7,10,7,0)_100%)]"></div> -->
        </div>
    </div>
</section>
