---
import logo from '../assets/logo-sunka-black.webp'
import Menu from '../assets/icons/menu.astro'
import XmakIcon from '../assets/icons/xmark.astro'
import CartIcon from '../components/CartIcon.vue'
import AuthModal from '../components/AuthModal.vue'

const navLinks = [
    { nombre: 'Origen', href: '/origen' },
    { nombre: 'Inspiración', href: '/inspiracion' },
    { nombre: 'Tienda', href: '/tienda' },
    { nombre: 'Blends', href: '/crea-tu-blend' },
]
---

<header id="site-header" class="w-full sticky top-0 z-50 bg-white transition-all duration-500">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-20">
        <!-- Logo -->
        <a href="/" class="flex items-center">
            <img
                src={logo.src}
                alt="SUNKA"
                class="h-8 w-auto transition-opacity duration-300 hover:opacity-70"
            />
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-12">
            {
                navLinks.map((link) => (
                    <a
                        href={link.href}
                        class="text-sm tracking-wide uppercase text-neutral-800
                   transition-opacity duration-300 hover:opacity-50"
                    >
                        {link.nombre}
                    </a>
                ))
            }
        </nav>

        <!-- Right -->
        <div class="flex items-center gap-6">
            <AuthModal client:load />
            <CartIcon client:load />

            <button id="menu-toggle" class="md:hidden text-neutral-900">
                <div id="icon-menu">
                    <Menu />
                </div>
                <div id="icon-close" class="hidden">
                    <XmakIcon />
                </div>
            </button>
        </div>
    </div>
</header>

<!-- Mobile Menu -->
<div
    id="mobile-menu"
    class="fixed inset-0 bg-white flex flex-col justify-center items-center
         transform translate-x-full transition-transform duration-500
         z-40 md:hidden"
>
    <div class="flex flex-col gap-10 text-center">
        {
            navLinks.map((link) => (
                <a
                    href={link.href}
                    class="text-2xl font-heading tracking-wide text-neutral-900
                 transition-opacity duration-300 hover:opacity-50"
                >
                    {link.nombre}
                </a>
            ))
        }
    </div>
</div>

<script>
    const header = document.getElementById('site-header')
    const toggleBtn = document.getElementById('menu-toggle')
    const mobileMenu = document.getElementById('mobile-menu')
    const iconMenu = document.getElementById('icon-menu')
    const iconClose = document.getElementById('icon-close')

    // Solo efecto visual (NO cambio de posición)
    window.addEventListener('scroll', () => {
        if (window.scrollY > 40) {
            header.classList.add('bg-white/80', 'backdrop-blur-md', 'shadow-sm')
        } else {
            header.classList.remove('bg-white/80', 'backdrop-blur-md', 'shadow-sm')
        }
    })

    toggleBtn?.addEventListener('click', () => {
        const isOpen = mobileMenu.classList.contains('translate-x-0')

        if (isOpen) {
            mobileMenu.classList.remove('translate-x-0')
            mobileMenu.classList.add('translate-x-full')
            iconMenu.classList.remove('hidden')
            iconClose.classList.add('hidden')
        } else {
            mobileMenu.classList.remove('translate-x-full')
            mobileMenu.classList.add('translate-x-0')
            iconMenu.classList.add('hidden')
            iconClose.classList.remove('hidden')
        }
    })
</script>
