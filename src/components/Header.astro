---
import logo from '../assets/logo-sunka-white.webp'
import Menu from '../assets/icons/menu.astro'
import XmakIcon from '../assets/icons/xmark.astro'
import CartIcon from '../components/CartIcon.vue'
import AuthModal from '../components/AuthModal.vue'
import HeaderTopBar from '../components/HeaderTopBar.astro'
import SearchIcon from '../assets/icons/icon-search.astro'

const leftNavLinks = [
    { nombre: 'Tienda', href: '/tienda' },
    { nombre: 'Crea tu blend', href: '/crea-tu-blend' },
    { nombre: 'Rituales', href: '/inspiracion' },
]

const rightNavLinks = [
    { nombre: 'Regalos', href: '/tienda' },
    { nombre: 'Origen', href: '/origen' },
    { nombre: 'Club Sunka', href: '/account' },
]

const mobileNavLinks = [...leftNavLinks, ...rightNavLinks]
---

<header id="site-header" class="relative z-50 w-full text-sunka-white">
    <div class="h-7" aria-hidden="true"></div>
    <div class="fixed top-0 left-0 z-[60] w-full">
        <HeaderTopBar />
    </div>

    <div
        id="site-header-main"
        class="fixed top-7 left-0 z-50 w-full border-b border-transparent bg-transparent transition-all duration-500"
    >
        <div
            class="relative mx-auto grid h-16 max-w-7xl grid-cols-[1fr_auto_1fr] items-center gap-4 px-5 md:h-[76px] md:px-8"
        >
            <nav class="hidden items-center gap-8 md:flex lg:gap-11">
                {
                    leftNavLinks.map((link) => (
                        <a
                            href={link.href}
                            class="text-[12px] font-semibold uppercase tracking-[0.12em] text-sunka-white/90 transition-colors duration-300 hover:text-sunka-brass-light"
                        >
                            {link.nombre}
                        </a>
                    ))
                }
            </nav>

            <button
                id="menu-toggle"
                class="flex h-10 w-10 items-center justify-center text-sunka-white md:hidden"
                aria-label="Abrir menu"
            >
                <div id="icon-menu">
                    <Menu />
                </div>
                <div id="icon-close" class="hidden">
                    <XmakIcon />
                </div>
            </button>

            <a href="/" class="flex items-center justify-center">
                <img
                    src={logo.src}
                    alt="SUNKA"
                    class="h-10 w-auto transition-opacity duration-300 hover:opacity-75 md:h-12"
                />
            </a>

            <div class="flex items-center justify-end gap-5 md:gap-7">
                <nav class="hidden items-center gap-8 md:flex lg:gap-11">
                    {
                        rightNavLinks.map((link) => (
                            <a
                                href={link.href}
                                class="text-[12px] font-semibold uppercase tracking-[0.12em] text-sunka-white/90 transition-colors duration-300 hover:text-sunka-brass-light"
                            >
                                {link.nombre}
                            </a>
                        ))
                    }
                </nav>

                <div class="flex items-center gap-4 text-sunka-white md:gap-5">
                    <AuthModal client:load />
                    <CartIcon client:load />
                    <a
                        href="/tienda"
                        class="hidden text-sunka-white transition-colors duration-300 hover:text-sunka-brass-light md:flex"
                        aria-label="Buscar productos"
                    >
                        <SearchIcon />
                    </a>
                </div>
            </div>
        </div>
    </div>
</header>

<div
    id="mobile-menu"
    class="fixed inset-0 z-40 flex translate-x-full transform flex-col items-center justify-center bg-sunka-cream transition-transform duration-500 md:hidden"
>
    <div class="flex flex-col gap-8 text-center">
        {
            mobileNavLinks.map((link) => (
                <a
                    href={link.href}
                    class="font-heading text-2xl uppercase tracking-[0.08em] text-sunka-ink transition-colors duration-300 hover:text-sunka-brass"
                >
                    {link.nombre}
                </a>
            ))
        }
    </div>
</div>

<script>
    const headerMain = document.getElementById('site-header-main')
    const toggleBtn = document.getElementById('menu-toggle')
    const mobileMenu = document.getElementById('mobile-menu')
    const iconMenu = document.getElementById('icon-menu')
    const iconClose = document.getElementById('icon-close')

    // Solo efecto visual para reforzar legibilidad al hacer scroll.
    window.addEventListener('scroll', () => {
        if (window.scrollY > 4) {
            headerMain?.classList.add('border-sunka-white/15', 'backdrop-blur-md', 'shadow-lg')
            headerMain?.classList.remove('border-transparent')
        } else {
            headerMain?.classList.remove('border-sunka-white/15', 'backdrop-blur-md', 'shadow-lg')
            headerMain?.classList.add('border-transparent')
        }
    })

    toggleBtn?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.contains('translate-x-0')

        if (isOpen) {
            mobileMenu?.classList.remove('translate-x-0')
            mobileMenu?.classList.add('translate-x-full')
            iconMenu?.classList.remove('hidden')
            iconClose?.classList.add('hidden')
        } else {
            mobileMenu?.classList.remove('translate-x-full')
            mobileMenu?.classList.add('translate-x-0')
            iconMenu?.classList.add('hidden')
            iconClose?.classList.remove('hidden')
        }
    })
</script>
