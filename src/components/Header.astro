---
import logo from '../assets/logo-sunka-white.webp'
import logoBlack from '../assets/logo-sunka-black.webp'
import Menu from '../assets/icons/menu.astro'
import XmakIcon from '../assets/icons/xmark.astro'
import CartIcon from '../components/CartIcon.vue'
import AuthModal from '../components/AuthModal.vue'
import HeaderTopBar from '../components/HeaderTopBar.astro'
import SearchIcon from '../assets/icons/icon-search.astro'

const leftNavLinks = [
    { nombre: 'Tienda', href: '/tienda' },
    { nombre: 'Crea tu blend', href: '/crea-tu-blend' },
    { nombre: 'Rituales', href: '/inspiracion' },
]

const rightNavLinks = [
    { nombre: 'Regalos', href: '/tienda' },
    { nombre: 'Origen', href: '/origen' },
    { nombre: 'Club Sunka', href: '/account' },
]

const mobileNavLinks = [...leftNavLinks, ...rightNavLinks]
const transparentHeaderPaths = ['/', '/lineas/signature']
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'
const startsTransparent = transparentHeaderPaths.includes(currentPath)
const headerMainClass = startsTransparent
    ? 'fixed top-7 left-0 z-50 w-full border-b border-transparent bg-transparent transition-all duration-500'
    : 'fixed top-7 left-0 z-50 w-full border-b border-sunka-white/10 bg-[#2b2b2b]/42 backdrop-blur-md transition-all duration-500'
---

<header id="site-header" class="relative z-50 w-full text-sunka-white">
    <div class="h-7" aria-hidden="true"></div>
    <div class="fixed top-0 left-0 z-[60] w-full">
        <HeaderTopBar />
    </div>

    <div id="site-header-main" class:list={[headerMainClass, 'text-sunka-white']}>
        <div
            class="relative mx-auto grid h-16 max-w-7xl grid-cols-[1fr_auto_1fr] items-center gap-4 px-5 lg:h-[76px] lg:px-8"
        >
            <nav class="hidden items-center gap-7 lg:flex xl:gap-11">
                {
                    leftNavLinks.map((link) => (
                        <a
                            href={link.href}
                            class="text-[12px] font-semibold uppercase tracking-[0.12em] text-current opacity-90 transition-colors duration-300 hover:text-sunka-brass-light hover:opacity-100"
                        >
                            {link.nombre}
                        </a>
                    ))
                }
            </nav>

            <button
                id="menu-toggle"
                class="flex h-10 w-10 items-center justify-center text-current lg:hidden"
                aria-label="Abrir menu"
                aria-expanded="false"
                aria-controls="mobile-menu"
            >
                <div id="icon-menu">
                    <Menu />
                </div>
                <div id="icon-close" class="hidden">
                    <XmakIcon />
                </div>
            </button>

            <a href="/" class="flex items-center justify-center">
                <img
                    id="site-logo-white"
                    src={logo.src}
                    alt="SUNKA"
                    class="h-10 w-auto transition-opacity duration-300 hover:opacity-75 lg:h-12"
                />
                <img
                    id="site-logo-black"
                    src={logoBlack.src}
                    alt="SUNKA"
                    class="hidden h-10 w-auto transition-opacity duration-300 hover:opacity-75 lg:h-12"
                />
            </a>

            <div class="flex items-center justify-end gap-5 lg:gap-7">
                <nav class="hidden items-center gap-7 lg:flex xl:gap-11">
                    {
                        rightNavLinks.map((link) => (
                            <a
                                href={link.href}
                                class="text-[12px] font-semibold uppercase tracking-[0.12em] text-current opacity-90 transition-colors duration-300 hover:text-sunka-brass-light hover:opacity-100"
                            >
                                {link.nombre}
                            </a>
                        ))
                    }
                </nav>

                <div class="flex items-center gap-4 text-current lg:gap-5">
                    <AuthModal client:load />
                    <CartIcon client:load />
                    <a
                        href="/tienda"
                        class="hidden text-current transition-colors duration-300 hover:text-sunka-brass-light lg:flex"
                        aria-label="Buscar productos"
                    >
                        <SearchIcon />
                    </a>
                </div>
            </div>
        </div>
    </div>
</header>

<div
    id="mobile-menu"
    class="fixed inset-0 z-40 flex translate-x-full transform flex-col items-center justify-center bg-sunka-cream transition-transform duration-500 lg:hidden"
>
    <div class="flex flex-col gap-8 text-center">
        {
            mobileNavLinks.map((link) => (
                <a
                    href={link.href}
                    class="font-heading text-2xl uppercase tracking-[0.08em] text-sunka-ink transition-colors duration-300 hover:text-sunka-brass"
                >
                    {link.nombre}
                </a>
            ))
        }
    </div>
</div>

<script>
    const headerMain = document.getElementById('site-header-main')
    const toggleBtn = document.getElementById('menu-toggle')
    const mobileMenu = document.getElementById('mobile-menu')
    const iconMenu = document.getElementById('icon-menu')
    const iconClose = document.getElementById('icon-close')
    const logoWhite = document.getElementById('site-logo-white')
    const logoBlack = document.getElementById('site-logo-black')
    const transparentHeaderPaths = ['/', '/lineas/signature']
    const currentPath = window.location.pathname.replace(/\/$/, '') || '/'
    const isTransparentHeaderPage = transparentHeaderPaths.includes(currentPath)

    const setMenuOpen = (isOpen) => {
        mobileMenu?.classList.toggle('translate-x-0', isOpen)
        mobileMenu?.classList.toggle('translate-x-full', !isOpen)
        iconMenu?.classList.toggle('hidden', isOpen)
        iconClose?.classList.toggle('hidden', !isOpen)
        logoWhite?.classList.toggle('hidden', isOpen)
        logoBlack?.classList.toggle('hidden', !isOpen)
        headerMain?.classList.toggle('text-sunka-white', !isOpen)
        headerMain?.classList.toggle('text-sunka-ink', isOpen)
        headerMain?.classList.toggle('bg-transparent', isOpen)
        headerMain?.classList.toggle('border-transparent', isOpen)
        headerMain?.classList.remove(
            'bg-[#2b2b2b]/42',
            'bg-[#2b2b2b]/58',
            'backdrop-blur-md',
            'border-sunka-white/10',
            'shadow-lg',
        )
        toggleBtn?.setAttribute('aria-expanded', String(isOpen))
        document.body.style.overflow = isOpen ? 'hidden' : ''

        if (!isOpen) updateHeaderBackground()
    }

    const updateHeaderBackground = () => {
        if (mobileMenu?.classList.contains('translate-x-0')) return

        if (!isTransparentHeaderPage) {
            headerMain?.classList.add('bg-[#2b2b2b]/42', 'backdrop-blur-md', 'border-sunka-white/10')
            headerMain?.classList.remove('bg-transparent', 'border-transparent', 'shadow-lg')
        } else if (window.scrollY > 4) {
            headerMain?.classList.add(
                'bg-[#2b2b2b]/58',
                'backdrop-blur-md',
                'border-sunka-white/10',
                'shadow-lg',
            )
            headerMain?.classList.remove('bg-transparent', 'border-transparent')
        } else {
            headerMain?.classList.remove(
                'bg-[#2b2b2b]/58',
                'backdrop-blur-md',
                'border-sunka-white/10',
                'shadow-lg',
            )
            headerMain?.classList.add('bg-transparent', 'border-transparent')
        }
    }

    if (isTransparentHeaderPage) {
        updateHeaderBackground()
        window.addEventListener('scroll', updateHeaderBackground)
    }

    toggleBtn?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.contains('translate-x-0')
        setMenuOpen(!isOpen)
    })

    document.querySelectorAll('#mobile-menu a').forEach((link) => {
        link.addEventListener('click', () => setMenuOpen(false))
    })
</script>
