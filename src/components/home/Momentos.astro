---
const moments = [
    {
        title: 'Para empezar el dia',
        icon: 'sun',
    },
    {
        title: 'Para la oficina',
        icon: 'briefcase',
    },
    {
        title: 'Despues de comer',
        icon: 'leaf',
    },
    {
        title: 'Para relajarte',
        icon: 'lotus',
    },
    {
        title: 'Para dormir',
        icon: 'moon',
    },
    {
        title: 'Para compartir',
        icon: 'users',
    },
    {
        title: 'Para regalar',
        icon: 'gift',
    },
]
---

<section class="border-b border-sunka-sand bg-sunka-cream py-9 md:py-11">
    <div class="mx-auto max-w-7xl px-5 md:px-8">
        <div class="text-center">
            <h2 class="font-heading text-2xl font-semibold leading-tight text-sunka-ink md:text-3xl">
                ¿Que momento vas a vivir hoy?
            </h2>
            <p class="mt-1 text-sm text-sunka-ink/70">
                Encuentra tu infusion ideal segun tu momento.
            </p>
        </div>

        <div class="mt-9 grid grid-cols-2 gap-x-5 gap-y-9 sm:grid-cols-3 md:mt-10 md:grid-cols-7">
            {
                moments.map((moment) => (
                    <a href="/tienda" class="group flex flex-col items-center text-center">
                        <span class="flex h-[72px] w-[72px] items-center justify-center rounded-full bg-sunka-sand/70 text-sunka-ink transition-all duration-300 group-hover:bg-sunka-brass group-hover:text-sunka-white md:h-[78px] md:w-[78px]">
                            {moment.icon === 'sun' && (
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="34"
                                    height="34"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.4"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <circle cx="12" cy="12" r="4"></circle>
                                    <path d="M12 2v2"></path>
                                    <path d="M12 20v2"></path>
                                    <path d="m4.93 4.93 1.41 1.41"></path>
                                    <path d="m17.66 17.66 1.41 1.41"></path>
                                    <path d="M2 12h2"></path>
                                    <path d="M20 12h2"></path>
                                    <path d="m6.34 17.66-1.41 1.41"></path>
                                    <path d="m19.07 4.93-1.41 1.41"></path>
                                </svg>
                            )}
                            {moment.icon === 'briefcase' && (
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="34"
                                    height="34"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.4"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path d="M10 6V5a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v1"></path>
                                    <rect x="3" y="6" width="18" height="14" rx="2"></rect>
                                    <path d="M3 12h18"></path>
                                    <path d="M12 12v.01"></path>
                                </svg>
                            )}
                            {moment.icon === 'leaf' && (
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="34"
                                    height="34"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.4"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path d="M5 21c7-1 13-7 14-16-9 1-15 7-16 14"></path>
                                    <path d="M9 15c2 0 5-2 7-6"></path>
                                </svg>
                            )}
                            {moment.icon === 'lotus' && (
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="34"
                                    height="34"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.4"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path d="M12 20c-5-2-7-6-6-11 4 1 6 4 6 9"></path>
                                    <path d="M12 20c5-2 7-6 6-11-4 1-6 4-6 9"></path>
                                    <path d="M12 18c-3-3-3-8 0-13 3 5 3 10 0 13"></path>
                                </svg>
                            )}
                            {moment.icon === 'moon' && (
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="34"
                                    height="34"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.4"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path d="M20 14.5A8 8 0 0 1 9.5 4 8.5 8.5 0 1 0 20 14.5Z"></path>
                                </svg>
                            )}
                            {moment.icon === 'users' && (
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="34"
                                    height="34"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.4"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path d="M16 21v-2a4 4 0 0 0-8 0v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                    <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                    <path d="M2 21v-2a4 4 0 0 1 3-3.87"></path>
                                    <path d="M8 3.13a4 4 0 0 0 0 7.75"></path>
                                </svg>
                            )}
                            {moment.icon === 'gift' && (
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="34"
                                    height="34"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.4"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <rect x="3" y="8" width="18" height="13" rx="1"></rect>
                                    <path d="M12 8v13"></path>
                                    <path d="M3 12h18"></path>
                                    <path d="M12 8H8.5a2.5 2.5 0 1 1 2.2-3.7L12 8Z"></path>
                                    <path d="M12 8h3.5a2.5 2.5 0 1 0-2.2-3.7L12 8Z"></path>
                                </svg>
                            )}
                        </span>
                        <span class="mt-3 max-w-[110px] text-sm font-medium leading-snug text-sunka-ink">
                            {moment.title}
                        </span>
                    </a>
                ))
            }
        </div>
    </div>
</section>
