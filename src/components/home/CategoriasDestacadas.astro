---
import tetera from '@/assets/home/banner/tetera.webp'
import campo from '@/assets/home/banner/campo.webp'
import tazas from '@/assets/home/banner/tazas.webp'
import ingredientes from '@/assets/home/ingredientes.webp'
import preparacion from '@/assets/home/preparacion.webp'
import momentoPersonal from '@/assets/home/momento-personal.webp'

const colecciones = [
    {
        nombre: 'Signature Black',
        detalle: 'Sunka x Mambroc',
        href: '/tienda',
        imagen: tetera.src,
        posicion: 'object-left',
    },
    {
        nombre: 'Piramidal Premium',
        detalle: 'Infusiones en piramide',
        href: '/tienda',
        imagen: tazas.src,
        posicion: 'object-center',
    },
    {
        nombre: 'Luxury Collection',
        detalle: 'Ediciones especiales',
        href: '/tienda',
        imagen: momentoPersonal.src,
        posicion: 'object-center',
    },
    {
        nombre: 'Tradicionales',
        detalle: 'Sabores de siempre',
        href: '/tienda',
        imagen: ingredientes.src,
        posicion: 'object-center',
    },
    {
        nombre: 'RTD - Listo para tomar',
        detalle: 'Bienestar en movimiento',
        href: '/tienda',
        imagen: campo.src,
        posicion: 'object-center',
    },
    {
        nombre: 'Granel',
        detalle: 'Elige a tu medida',
        href: '/tienda',
        imagen: preparacion.src,
        posicion: 'object-center',
    },
]
---

<section class="bg-sunka-cream py-8 md:py-10">
    <div class="mx-auto max-w-7xl px-5 md:px-8">
        <div class="mb-6 text-center md:mb-8">
            <h2 class="font-heading text-2xl font-semibold leading-tight text-sunka-ink md:text-3xl">
                Nuestras colecciones
            </h2>
            <p class="mt-1 text-sm text-sunka-ink/70">
                Descubre nuestras lineas y elige tu favorita.
            </p>
        </div>

        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-6">
            {
                colecciones.map((coleccion) => (
                    <a
                        href={coleccion.href}
                        class="group relative flex h-[210px] overflow-hidden rounded-md bg-sunka-ink text-sunka-white sm:h-[230px] lg:h-[205px]"
                    >
                        <img
                            src={coleccion.imagen}
                            alt={coleccion.nombre}
                            class={`absolute inset-0 h-full w-full object-cover ${coleccion.posicion} transition-transform duration-[2500ms] ease-out group-hover:scale-105`}
                        />

                        <div class="absolute inset-0 bg-black/38 transition-colors duration-300 group-hover:bg-black/25"></div>

                        <div class="relative z-10 flex h-full w-full flex-col justify-end p-5 text-center">
                            <p class="text-[13px] font-semibold uppercase tracking-[0.08em]">
                                {coleccion.nombre}
                            </p>
                            <p class="mt-1 text-sm text-sunka-white/90">{coleccion.detalle}</p>
                            <span class="mt-4 text-sm text-sunka-white/95">
                                Ver coleccion
                                <span
                                    aria-hidden="true"
                                    class="inline-block transition-transform duration-300 group-hover:translate-x-1"
                                >
                                    →
                                </span>
                            </span>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</section>
