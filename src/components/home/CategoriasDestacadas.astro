---
import signature from '@/assets/home/lineas/signature.webp'
import piramidal from '@/assets/home/lineas/piramidal.webp'
import luxury from '@/assets/home/lineas/luxury.webp'
import granel from '@/assets/home/lineas/granel.webp'
import tradicional from '@/assets/home/lineas/tradicional.webp'

const colecciones = [
    {
        nombre: 'Signature Black',
        detalle: 'Sunka x Mambroc',
        href: '/tienda',
        imagen: signature.src,
        posicion: 'object-left',
    },
    {
        nombre: 'Piramidal Premium',
        detalle: 'Infusiones en piramide',
        href: '/tienda',
        imagen: piramidal.src,
        posicion: 'object-bottom',
    },
    {
        nombre: 'Luxury Collection',
        detalle: 'Ediciones especiales',
        href: '/tienda',
        imagen: luxury.src,
        posicion: 'object-top',
    },
    {
        nombre: 'Tradicionales',
        detalle: 'Sabores de siempre',
        href: '/tienda',
        imagen: tradicional.src,
        posicion: 'object-center',
    },
    // {
    //     nombre: 'RTD - Listo para tomar',
    //     detalle: 'Bienestar en movimiento',
    //     href: '/tienda',
    //     imagen: campo.src,
    //     posicion: 'object-center',
    // },
    {
        nombre: 'Granel',
        detalle: 'Elige a tu medida',
        href: '/tienda',
        imagen: granel.src,
        posicion: 'object-center',
    },
]
---

<section class="bg-sunka-cream py-8 md:py-10">
    <div class="mx-auto max-w-7xl px-5 md:px-8">
        <div class="mb-6 text-center md:mb-8">
            <h2
                class="font-heading text-2xl font-semibold leading-tight text-sunka-ink md:text-3xl"
            >
                Nuestras colecciones
            </h2>
            <p class="mt-1 text-sm text-sunka-ink/70">
                Descubre nuestras lineas y elige tu favorita.
            </p>
        </div>

        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-5">
            {
                colecciones.map((coleccion) => (
                    <a
                        href={coleccion.href}
                        class="group relative flex h-[245px] overflow-hidden rounded-md bg-sunka-ink text-sunka-white sm:h-[270px] lg:h-[255px]"
                    >
                        <img
                            src={coleccion.imagen}
                            alt={coleccion.nombre}
                            class={`absolute inset-0 h-full w-full object-cover ${coleccion.posicion} transition-transform duration-[2500ms] ease-out group-hover:scale-105`}
                        />

                        <div class="absolute inset-x-0 bottom-0 h-[45%] bg-[linear-gradient(180deg,rgba(42,42,31,0)_0%,rgba(42,42,31,.7)_48%,rgba(42,42,31,.96)_100%)] transition-opacity duration-300 group-hover:opacity-80" />

                        <div class="relative z-10 flex h-full w-full flex-col justify-end p-4 text-center">
                            <p class="text-[13px] font-semibold uppercase tracking-[0.08em]">
                                {coleccion.nombre}
                            </p>
                            <span class="mt-2 text-sm text-sunka-sand">
                                Ver coleccion
                                <span
                                    aria-hidden="true"
                                    class="inline-block transition-transform duration-300 group-hover:translate-x-1"
                                >
                                    &rarr;
                                </span>
                            </span>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</section>
