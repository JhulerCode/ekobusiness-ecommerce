---
import banner1 from '@/assets/banner1.webp'
import banner2 from '@/assets/banner2.webp'

const banners = [banner1, banner2]
---

<section class="relative w-full h-[85vh] md:h-[150vh] overflow-hidden">
    <!-- Imágenes -->
    {
        banners.map((b, i) => (
            <img
                src={b.src}
                alt="Ritual SUNKA"
                class="banner-fade"
                style={`animation-delay: ${i * 8}s`}
            />
        ))
    }

    <!-- Overlay elegante -->
    <div class="absolute inset-0 bg-black/30"></div>

    <!-- Contenido -->
    <div
        class="absolute inset-0 flex flex-col items-center justify-center text-center px-6 fade-up"
    >
        <h1
            class="text-white font-heading text-4xl md:text-6xl font-semibold leading-tight max-w-4xl"
        >
            Un ritual de pausa
            <br class="hidden md:block" />
            en cada taza
        </h1>

        <p class="mt-6 text-white/90 text-lg md:text-xl max-w-2xl leading-relaxed">
            Mezclas herbales diseñadas para acompañar tus momentos de claridad, equilibrio y
            bienestar.
        </p>

        <a
            href="/tienda"
            class="mt-10 inline-block px-8 py-3 border border-white text-white
             tracking-wide text-sm uppercase
             transition-all duration-500
             hover:bg-white hover:text-black"
        >
            Descubrir colección
        </a>
    </div>
</section>

<style>
    .banner-fade {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        opacity: 0;
        animation: bannerFade 16s infinite;
        transform: scale(1);
    }

    @keyframes bannerFade {
        0% {
            opacity: 0;
            transform: scale(1);
        }
        10% {
            opacity: 1;
        }
        40% {
            opacity: 1;
            transform: scale(1.05);
        }
        50% {
            opacity: 0;
        }
        100% {
            opacity: 0;
            transform: scale(1.10);
        }
    }
</style>
