---
import campo from '@/assets/home/banner/campo.webp'
import tazas from '@/assets/home/banner/tazas.webp'
import tetera from '@/assets/home/banner/tetera.webp'

const slides = [
    { src: tetera.src, alt: 'Ritual SUNKA con tetera e infusion', position: 'object-center' },
    { src: campo.src, alt: 'Campo de cultivo SUNKA en los Andes', position: 'object-center' },
    { src: tazas.src, alt: 'Tazas de infusion SUNKA en un paisaje andino', position: 'object-center' },
]
---

<section class="relative min-h-[520px] w-full overflow-hidden bg-sunka-ink md:min-h-[650px]">
    {
        slides.map((slide, index) => (
            <img
                src={slide.src}
                alt={slide.alt}
                class={`banner-slide absolute inset-0 h-full w-full object-cover ${slide.position}`}
                style={`animation-delay: ${index * 6}s`}
            />
        ))
    }

    <div class="relative z-10 mx-auto flex min-h-[520px] max-w-7xl items-center px-5 pt-20 md:min-h-[650px] md:px-8 md:pt-24">
        <div class="max-w-2xl text-sunka-white fade-up">
            <!-- <p class="mb-4 text-xs font-semibold uppercase tracking-[0.28em] text-sunka-brass-light/90">
                Infusiones & tes
            </p> -->

            <h1 class="max-w-xl font-heading text-4xl font-semibold leading-[1.05] md:text-6xl">
                El ritual peruano del bienestar moderno
            </h1>

            <p class="mt-6 max-w-md text-base leading-relaxed text-sunka-white/88 md:text-lg">
                Tes, infusiones y blends creados para transformar cada pausa en una experiencia
                sensorial.
            </p>

            <div class="mt-9 flex flex-col gap-3 sm:flex-row">
                <a
                    href="/inspiracion"
                    class="inline-flex h-11 items-center justify-center border border-sunka-brass bg-sunka-brass px-6 text-[12px] font-semibold uppercase tracking-[0.12em] text-sunka-white transition-all duration-300 hover:bg-sunka-brass-light hover:text-sunka-ink"
                >
                    Descubrir mi ritual
                </a>
                <a
                    href="/tienda"
                    class="inline-flex h-11 items-center justify-center border border-sunka-white/55 px-6 text-[12px] font-semibold uppercase tracking-[0.12em] text-sunka-white transition-all duration-300 hover:border-sunka-white hover:bg-sunka-white hover:text-sunka-ink"
                >
                    Comprar coleccion
                </a>
                <a
                    href="/crea-tu-blend"
                    class="inline-flex h-11 items-center justify-center border border-sunka-white/35 px-6 text-[12px] font-semibold uppercase tracking-[0.12em] text-sunka-white transition-all duration-300 hover:border-sunka-brass-light hover:text-sunka-brass-light"
                >
                    Crear mi blend
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    .banner-slide {
        opacity: 0;
        animation: bannerSlideFade 18s infinite;
    }

    @keyframes bannerSlideFade {
        0% {
            opacity: 0;
        }
        8% {
            opacity: 1;
        }
        33% {
            opacity: 1;
        }
        41% {
            opacity: 0;
        }
        100% {
            opacity: 0;
        }
    }
</style>
