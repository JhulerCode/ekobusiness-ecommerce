---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '@/components/origen/Hero.astro'
import Leyenda from '@/components/origen/Leyenda.astro'
import Significado from '@/components/origen/Significado.astro'
import Comunidad from '@/components/origen/Comunidad.astro'
import Proposito from '@/components/origen/Proposito.astro'
import Cita from '@/components/origen/Cita.astro'
---

<BaseLayout
    title="Origen | SUNKA Herbal Tea"
    description="Descubre el origen de SUNKA, inspirado en la sabiduría ancestral de las comunidades andinas del Perú. Una historia de infusión, ritual y conexión con la naturaleza."
>
    <Hero />
    <Leyenda />
    <Significado />
    <Comunidad />
    <Proposito />
    <Cita />
</BaseLayout>
